// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  BANNED
  PENDING_DELETE
  DELETED
}

enum UserRole {
  USER
  SCORER
  ADMIN
  SUPER_ADMIN
}

enum MembershipStatus {
  PENDING
  VERIFIED
  EXPIRED
  REJECTED
  REVOKED
  LEFT_PENDING_REVIEW
  LEFT_CONFIRMED
  RESTORED
  REMOVED
}


enum ProfileStatus {
  DRAFT
  ACTIVE
  HIDDEN
  CLEARED
  FROZEN
}

enum PhotoMatchPref {
  PHOTO_ONLY   // only match with other photo users
  ALL          // match with all users
}

enum Attribute {
  ONE
  ZERO
  HALF
  LEAN_ONE
  LEAN_ZERO
  SIDE
  OTHER
}

enum LocationType {
  RESIDENCE   // 常住地
  HOMETOWN    // 家乡
  SCHOOL      // 就读地
  WORK        // 工作地
  TRAVEL      // 旅居地
  OTHER       // 其他
}

enum LocationScope {
  CITY
  PROVINCE
  ANY
}

enum RatingStatus {
  NOT_SUBMITTED
  PENDING
  SCORING
  REVIEW
  COMPLETED
  NEEDS_RESCORE
  WITHDRAWN
}



enum RatingTaskStatus {
  PENDING
  SCORING
  REVIEW
  COMPLETED
  NEEDS_RESCORE
  REPORTED
}

enum ViewRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum ReportType {
  FAKE_INFO
  STOLEN_PHOTO
  IMPERSONATION
  HARASSMENT
  SCAM
  MALICIOUS
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWING
  ACCEPTED
  REJECTED
}

enum PenaltyType {
  WARNING
  ACCOUNT_BANNED
}

// ─── Models ───────────────────────────────────────────

/// Core user account — every person in the system has exactly one User record
model User {
  id            String     @id @default(cuid())
  qqNumber      String?    @unique  // QQ号 — primary login identifier
  passwordHash  String?              // bcrypt hash of passcode
  status        UserStatus @default(ACTIVE)
  role          UserRole   @default(USER)
  lastLoginAt   DateTime?
  lastProfileClearedAt DateTime?  // tracks 30-day publish cooldown after clear
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  authIdentities    AuthIdentity[]
  groupMembership   GroupMembership?
  profile           Profile?
  preference        Preference?
  ratingProfile     RatingProfile?


  // Membership verifications performed by this user (admin)
  verifiedMemberships GroupMembership[] @relation("MembershipVerifier")
  revokedMemberships  GroupMembership[] @relation("MembershipRevoker")

  // Rating
  ratingTasks        RatingTask[]  @relation("RatedUser")
  ratingScores       RatingScore[] @relation("Scorer")

  // Matching & Requests
  matchesAsUser      MatchSnapshot[] @relation("MatchUser")
  matchesAsTarget    MatchSnapshot[] @relation("MatchTarget")
  sentViewRequests   ViewRequest[]   @relation("ViewRequester")
  receivedViewRequests ViewRequest[] @relation("ViewTarget")

  // Reports & Penalties
  filedReports       Report[]  @relation("Reporter")
  receivedReports    Report[]  @relation("ReportTarget")
  handledReports     Report[]  @relation("ReportHandler")
  penalties          Penalty[] @relation("PenaltyTarget")
  issuedPenalties    Penalty[] @relation("PenaltyIssuer")

  // Audit
  auditLogs          AuditLog[]

  // Notifications
  notifications      Notification[]

  @@map("users")
}

/// OAuth identity from QQ or other providers
model AuthIdentity {
  id                    String   @id @default(cuid())
  userId                String
  provider              String   // e.g. "qq", "qq_connect"
  providerUserId        String   // raw ID from provider
  openid                String
  unionid               String?
  nickname              String?
  avatarUrl             String?
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, openid])
  @@map("auth_identities")
}

/// Group membership verification status
model GroupMembership {
  id              String           @id @default(cuid())
  userId          String           @unique
  qqNumber        String
  groupId         String           @default("default")
  status          MembershipStatus @default(PENDING)
  verifiedAt      DateTime?
  expiresAt       DateTime?
  verifiedBy      String?
  revokedAt       DateTime?
  revokedBy       String?
  remark          String?
  // Bot leave-detection fields
  leftDetectedAt  DateTime?        // When bot detected user left the group
  leftConfirmedAt DateTime?        // When admin confirmed user left
  restoredAt      DateTime?        // When admin restored user
  removedAt       DateTime?        // When admin purged user data
  leaveType       String?          // 'leave' | 'kick' | 'unknown'
  reviewReason    String?          // Reason shown in admin review
  reviewedBy      String?          // Admin who handled the review
  reviewRemark    String?          // Admin notes
  rawEvent        Json?            // Raw bot event that triggered status change
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifier User? @relation("MembershipVerifier", fields: [verifiedBy], references: [id])
  revoker  User? @relation("MembershipRevoker", fields: [revokedBy], references: [id])

  @@index([qqNumber])
  @@index([status])
  @@map("group_memberships")
}

/// User profile with personal information
model Profile {
  id                       String         @id @default(cuid())
  userId                   String         @unique
  birthDate                DateTime
  heightCm                 Int
  weightKg                 Int
  provinceCode             String
  cityCode                 String
  locationType             LocationType   @default(RESIDENCE)
  attribute                Attribute
  isSide                   Boolean        @default(false)
  isOther                  Boolean        @default(false)
  customAttribute          String?        @db.VarChar(20)
  mbti                     String?        @db.VarChar(4)
  selfIntro                String?
  consentProfileVisibility Boolean        @default(false)
  status                   ProfileStatus  @default(DRAFT)
  lastSubmittedAt          DateTime?
  // Photo matching preferences (only relevant when user has photos)
  photoMatchPref           PhotoMatchPref?  // null = no photos
  highScoreOnly            Boolean        @default(false) // only match ≥7.0
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("profiles")

  photos ProfilePhoto[]
}

/// User's profile photos, stored in MinIO (S3-compatible)
model ProfilePhoto {
  id          String   @id @default(cuid())
  profileId   String
  storageKey  String   // MinIO object key, e.g. "photos/userId/uuid.webp"
  order       Int      @default(0)   // display order (0-based)
  originalName String?
  mimeType    String?  @db.VarChar(100)
  sizeBytes   Int?
  createdAt   DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, order])
  @@map("profile_photos")
}

/// User preference / expected conditions for matching
model Preference {
  id                   String       @id @default(cuid())
  userId               String       @unique
  ageMin               Int
  ageMax               Int
  heightMinCm          Int
  heightMaxCm          Int
  weightMinKg          Int
  weightMaxKg          Int
  locationScope        LocationScope @default(ANY)
  expectedProvinceCode String?
  expectedCityCode     String?
  expectedAttributes   Json         // Array of Attribute enum values
  expectedCustomAttribute String? @db.VarChar(20)  // custom text when OTHER in expectedAttributes
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("preferences")
}

/// Rating profile — tracks scoring status for users with photos
model RatingProfile {
  id                       String             @id @default(cuid())
  userId                   String             @unique
  ratingStatus             RatingStatus       @default(NOT_SUBMITTED)
  finalScore               Float?
  scoreCompletedAt         DateTime?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rating_profiles")
}

/// A rating task assigned to all scorers for one user's photo
model RatingTask {
  id              String          @id @default(cuid())
  ratedUserId     String
  photoObjectKey  String
  status          RatingTaskStatus @default(PENDING)
  scorerSnapshot  Json            // Array of scorer user IDs at task creation
  photoReports    Json?           // Array of { reporterId, reason, createdAt }
  completedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  ratedUser User          @relation("RatedUser", fields: [ratedUserId], references: [id])
  scores    RatingScore[]

  @@index([status])
  @@map("rating_tasks")
}

/// Individual score from one scorer for one rating task
model RatingScore {
  id            String   @id @default(cuid())
  ratingTaskId  String
  scorerUserId  String
  score         Float    // 0-10 with 0.5 steps
  createdAt     DateTime @default(now())

  ratingTask RatingTask @relation(fields: [ratingTaskId], references: [id], onDelete: Cascade)
  scorer     User       @relation("Scorer", fields: [scorerUserId], references: [id])

  @@unique([ratingTaskId, scorerUserId])
  @@map("rating_scores")
}

/// Cached match result (optional for MVP — can compute in real-time)
model MatchSnapshot {
  id           String   @id @default(cuid())
  userId       String
  targetUserId String
  matchType    String   // "mutual" | "one_way"
  direction    String   // "i_like_target" | "target_likes_me" | "mutual"
  score        Float?   // relevance score for sorting
  computedAt   DateTime @default(now())

  user   User @relation("MatchUser", fields: [userId], references: [id])
  target User @relation("MatchTarget", fields: [targetUserId], references: [id])

  @@unique([userId, targetUserId])
  @@index([userId, matchType])
  @@map("match_snapshots")
}

/// Request to view a one-way match's full profile
model ViewRequest {
  id           String            @id @default(cuid())
  requesterId  String
  targetUserId String
  status       ViewRequestStatus @default(PENDING)
  message      String?
  respondedAt  DateTime?
  expiresAt    DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  requester User @relation("ViewRequester", fields: [requesterId], references: [id])
  target    User @relation("ViewTarget", fields: [targetUserId], references: [id])

  @@index([requesterId, status])
  @@index([targetUserId, status])
  @@map("view_requests")
}

/// User report against another user
model Report {
  id                 String       @id @default(cuid())
  reporterId         String
  targetUserId       String
  type               ReportType
  description        String
  evidenceObjectKeys Json?        // Array of S3 keys for evidence screenshots
  status             ReportStatus @default(PENDING)
  resolution         String?
  handledBy          String?
  handledAt          DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  reporter User  @relation("Reporter", fields: [reporterId], references: [id])
  target   User  @relation("ReportTarget", fields: [targetUserId], references: [id])
  handler  User? @relation("ReportHandler", fields: [handledBy], references: [id])

  @@index([status])
  @@index([targetUserId])
  @@map("reports")
}

/// Penalty record (warning, ban)
model Penalty {
  id        String      @id @default(cuid())
  userId    String
  type      PenaltyType
  reason    String
  createdBy String
  expiresAt DateTime?
  revokedAt DateTime?
  createdAt DateTime    @default(now())

  user    User @relation("PenaltyTarget", fields: [userId], references: [id])
  creator User @relation("PenaltyIssuer", fields: [createdBy], references: [id])

  @@index([userId])
  @@map("penalties")
}

/// Immutable audit log of all system actions
model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String   // e.g. "LOGIN", "PROFILE_UPDATE", "PENALTY_CREATE"
  targetType  String?  // e.g. "User", "Profile", "InviteCode"
  targetId    String?
  metadata    Json?    // Additional context
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  actor User? @relation(fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Bot Module Models ───────────────────────────────

/// Bot identity — links QQ number to system user with bot-specific metadata
model BotIdentity {
  id                    String    @id @default(cuid())
  userId                String?
  qqNumber              String    @unique
  qqEmail               String
  qqNickname            String?
  qqAvatarUrl           String?
  qqAvatarSyncedAt      DateTime?
  groupId               String
  groupCard             String?
  groupCardStatus       String?   // 'valid' | 'invalid_format' | etc.
  groupCardSyncStatus   String?   // 'synced' | 'pending_sync' | 'sync_failed' | etc.
  groupCardSyncedAt     DateTime?
  registeredFromGroupId String
  lastCommandAt         DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([groupId])
  @@map("bot_identities")
}

/// Raw event log — every inbound NapCat/OneBot event
model BotEventLog {
  id           String   @id @default(cuid())
  eventId      String?  // Deduplication key
  platform     String   // 'napcat' | 'onebot' | 'other'
  eventType    String   // 'group_message' | 'group_member_joined' | etc.
  groupId      String?
  qqNumber     String?
  messageText  String?
  rawPayload   Json
  handled      Boolean  @default(false)
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([eventId])
  @@index([groupId])
  @@index([qqNumber])
  @@map("bot_event_logs")
}

/// Outbound bot action log — messages sent, cards set, API calls
model BotActionLog {
  id           String   @id @default(cuid())
  action       String   // 'send_group_msg' | 'set_group_card' | etc.
  groupId      String?
  qqNumber     String?
  status       String   // 'success' | 'failed' | 'error'
  request      Json?
  response     Json?
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([action])
  @@index([groupId])
  @@index([qqNumber])
  @@map("bot_action_logs")
}

/// Admin review for group membership anomalies
model AdminReview {
  id          String    @id @default(cuid())
  type        String    // 'group_membership_left' | 'group_card_violation' | etc.
  userId      String?
  status      String    @default("pending") // 'pending' | 'resolved' | 'dismissed'
  reason      String
  metadata    Json?     // Additional context (qqNumber, groupId, leaveType, etc.)
  handledBy   String?
  handledAt   DateTime?
  resolution  String?   // 'restored' | 'confirmed_left' | 'purged' | etc.
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type])
  @@index([userId])
  @@index([status])
  @@map("admin_reviews")
}

/// System notifications for users
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // SCORING_COMPLETE | VIEW_REQUEST_RECEIVED | VIEW_REQUEST_APPROVED | VIEW_REQUEST_REJECTED | PENALTY_WARNING | SYSTEM
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}
