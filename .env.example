# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://date_admin:replace-with-local-postgres-password@127.0.0.1:5432/date_system

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://tenmatch:replace-with-local-redis-password@127.0.0.1:6379/0

# ─── MinIO / S3 Storage ───────────────────────────────
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_ACCESS_KEY=replace-with-local-minio-user
MINIO_SECRET_KEY=replace-with-local-minio-password
MINIO_BUCKET=date-photos
MINIO_USE_SSL=false

# ─── QQ Bot ───────────────────────────────────────────
BOT_INTERNAL_SECRET=replace-with-random-local-secret
BOT_PROVIDER=napcat
BOT_TARGET_GROUP_ID=replace-with-group-number
BOT_WEBHOOK_TOKEN=replace-with-random-local-secret
BOT_QQ_NUMBER=replace-with-bot-qq-number           # QQ number for the bot account (used by Docker)

# ─── NapCat HTTP API ──────────────────────────────────
NAPCAT_HTTP_BASE_URL=http://127.0.0.1:3001
NAPCAT_ACCESS_TOKEN=replace-with-random-local-secret

# ─── Bot Rate Limits ─────────────────────────────────
BOT_REGISTER_RATE_LIMIT_MINUTES=5
BOT_REGISTER_MAX_PER_HOUR=3
BOT_REGISTER_MAX_PER_DAY=5
BOT_PASSWORD_RESET_RATE_LIMIT_MINUTES=10
BOT_PASSWORD_RESET_MAX_PER_DAY=5

# ─── Group Card ──────────────────────────────────────
GROUP_CARD_SEPARATOR=｜
GROUP_CARD_AUTO_FIX=true
GROUP_CARD_MIN_AGE=18
GROUP_CARD_MAX_AGE=100

# ─── Registration ────────────────────────────────────
EMAIL_CODE_EXPIRE_MINUTES=15
QQ_EMAIL_DOMAIN=qq.com

# ─── Email Provider ──────────────────────────────────
# "smtp" = QQ SMTP (testing, no domain needed)
# "resend" = Resend API (production, requires custom domain)
EMAIL_PROVIDER=smtp

# ─── QQ SMTP (for testing) ───────────────────────────
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@qq.com
SMTP_PASS=your-smtp-authorization-code
SMTP_FROM=your-email@qq.com

# ─── Resend (for production) ─────────────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM=noreply@yourdomain.com
# RESEND_SANDBOX_TO=your-email@gmail.com

# ─── App Auth ─────────────────────────────────────────
JWT_SECRET=replace-with-random-local-secret
JWT_EXPIRES_IN=7d
IMAGE_PROXY_SECRET=replace-with-independent-random-local-secret

# ─── App ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Maintenance mode
MAINTENANCE_MODE=false
# Optional. Server-side only. Use long random values; comma-separate multiple developer tokens.
# Developers can visit /maintenance?bypass=<token> once to set a temporary HttpOnly bypass cookie.
# API/scripts can send x-maintenance-bypass: <token> on each request.
# MAINTENANCE_BYPASS_TOKENS=replace-with-long-random-token
