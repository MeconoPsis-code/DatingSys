# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://date_admin:date_dev_password@localhost:5432/date_system

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MinIO / S3 Storage ───────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=date-photos
MINIO_USE_SSL=false

# ─── QQ Bot ───────────────────────────────────────────
BOT_INTERNAL_SECRET=change-me-in-production
BOT_PROVIDER=napcat
BOT_TARGET_GROUP_ID=934518445
BOT_WEBHOOK_TOKEN=change-me-in-production
BOT_QQ_NUMBER=3466526668                          # QQ number for the bot account (used by Docker)

# ─── NapCat HTTP API ──────────────────────────────────
NAPCAT_HTTP_BASE_URL=http://127.0.0.1:3001
NAPCAT_ACCESS_TOKEN=change-me-in-production

# ─── Bot Rate Limits ─────────────────────────────────
BOT_REGISTER_RATE_LIMIT_MINUTES=5
BOT_REGISTER_MAX_PER_HOUR=3
BOT_REGISTER_MAX_PER_DAY=5
BOT_PASSWORD_RESET_RATE_LIMIT_MINUTES=10
BOT_PASSWORD_RESET_MAX_PER_DAY=5

# ─── Group Card ──────────────────────────────────────
GROUP_CARD_SEPARATOR=｜
GROUP_CARD_AUTO_FIX=true
GROUP_CARD_MIN_AGE=18
GROUP_CARD_MAX_AGE=100

# ─── Registration ────────────────────────────────────
EMAIL_CODE_EXPIRE_MINUTES=15
QQ_EMAIL_DOMAIN=qq.com

# ─── Email Provider ──────────────────────────────────
# "smtp" = QQ SMTP (testing, no domain needed)
# "resend" = Resend API (production, requires custom domain)
EMAIL_PROVIDER=smtp

# ─── QQ SMTP (for testing) ───────────────────────────
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@qq.com
SMTP_PASS=your-smtp-authorization-code
SMTP_FROM=your-email@qq.com

# ─── Resend (for production) ─────────────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM=noreply@yourdomain.com
# RESEND_SANDBOX_TO=your-email@gmail.com

# ─── App Auth ─────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-random-32-bytes
JWT_EXPIRES_IN=7d

# ─── App ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
