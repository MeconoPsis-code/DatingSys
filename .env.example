# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://date_admin:date_dev_password@localhost:5432/date_system

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MinIO / S3 Storage ───────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=date-photos
MINIO_USE_SSL=false

# ─── QQ OAuth ─────────────────────────────────────────
QQ_CLIENT_ID=
QQ_CLIENT_SECRET=
QQ_REDIRECT_URI=http://localhost:3000/api/auth/qq/callback

# ─── App Auth ─────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-char-string-in-production
JWT_EXPIRES_IN=7d

# ─── App ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
