# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://date_admin:date_dev_password@localhost:5432/date_system

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MinIO / S3 Storage ───────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=date-photos
MINIO_USE_SSL=false

# ─── QQ Bot ───────────────────────────────────────────
BOT_INTERNAL_SECRET=change-me-in-production

# ─── Email (SMTP) ─────────────────────────────────────
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=Date System <your-email@qq.com>

# ─── App Auth ─────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-random-32-bytes
JWT_EXPIRES_IN=7d

# ─── App ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
