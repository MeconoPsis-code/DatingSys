# Copy to /etc/tenmatch/infra.env as root:root with mode 0600.
# This file is only for Docker Compose. Never expose it to the app service.
# Never copy credentials from the compromised host.
# Generate independent secrets with: openssl rand -hex 32

# Keep "no" through recovery and data validation. Change to
# "unless-stopped" only after the corresponding services are healthy.
INFRA_RESTART_POLICY=no
NAPCAT_RESTART_POLICY=no

# PostgreSQL (required by docker-compose.yml)
POSTGRES_USER=date_admin
POSTGRES_PASSWORD=
POSTGRES_DB=date_system

# Redis (required). The default Redis ACL user is disabled. A hex password
# avoids URL-encoding ambiguity in the app REDIS_URL.
REDIS_USERNAME=tenmatch
REDIS_PASSWORD=

# MinIO administrator credentials (required; never give these to the app).
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# NapCat is only started with: docker compose --profile bot up -d napcat
# The image starts as root for initialization, then drops to these IDs.
NAPCAT_UID=10001
NAPCAT_GID=10001
NAPCAT_WEBUI_TOKEN=
NAPCAT_WEBUI_PREFIX=
BOT_QQ_NUMBER=
