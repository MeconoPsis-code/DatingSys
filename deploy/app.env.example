# TenMatch application runtime environment.
#
# Render this file on a trusted machine, then install it as
# /etc/tenmatch/app.env with owner root:root and mode 0600. The systemd
# service reads only this file; infrastructure administrator credentials stay
# in /etc/tenmatch/infra.env and must never be copied here.
#
# Generate independent URL-safe secrets with: openssl rand -hex 32

NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://10match.date

# Start in maintenance mode. Change to false only after local health and
# business-flow checks pass. The optional tokens must also be long and random.
MAINTENANCE_MODE=true
MAINTENANCE_BYPASS_TOKENS=

# The password must match POSTGRES_PASSWORD in infra.env. A URL-safe hex value
# avoids ambiguous escaping while keeping the two files independently managed.
DATABASE_URL=postgresql://date_admin:REPLACE_WITH_URL_SAFE_HEX@127.0.0.1:5432/date_system

# Must match the dedicated Redis ACL user configured in infra.env.
REDIS_URL=redis://tenmatch:REPLACE_WITH_URL_SAFE_HEX@127.0.0.1:6379/0

# Use a bucket-scoped MinIO application account. Never put MINIO_ROOT_USER or
# MINIO_ROOT_PASSWORD in this file.
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_ACCESS_KEY=tenmatch-app
MINIO_SECRET_KEY=REPLACE_WITH_INDEPENDENT_URL_SAFE_HEX
MINIO_BUCKET=date-photos
MINIO_USE_SSL=false

JWT_SECRET=REPLACE_WITH_INDEPENDENT_URL_SAFE_HEX
JWT_EXPIRES_IN=7d
IMAGE_PROXY_SECRET=REPLACE_WITH_INDEPENDENT_URL_SAFE_HEX

# QQ bot application credentials. NapCat itself remains disabled until the
# website is healthy; pre-provisioning independent tokens is still required.
BOT_PROVIDER=napcat
BOT_TARGET_GROUP_ID=REPLACE_WITH_GROUP_NUMBER
BOT_WEBHOOK_TOKEN=REPLACE_WITH_INDEPENDENT_URL_SAFE_HEX
BOT_INTERNAL_SECRET=REPLACE_WITH_INDEPENDENT_URL_SAFE_HEX
NAPCAT_HTTP_BASE_URL=http://127.0.0.1:3001
NAPCAT_ACCESS_TOKEN=REPLACE_WITH_INDEPENDENT_URL_SAFE_HEX

BOT_REGISTER_RATE_LIMIT_MINUTES=5
BOT_REGISTER_MAX_PER_HOUR=3
BOT_REGISTER_MAX_PER_DAY=5
BOT_PASSWORD_RESET_RATE_LIMIT_MINUTES=10
BOT_PASSWORD_RESET_MAX_PER_DAY=5
GROUP_CARD_SEPARATOR=｜
GROUP_CARD_AUTO_FIX=true
GROUP_CARD_MIN_AGE=18
GROUP_CARD_MAX_AGE=100
EMAIL_CODE_EXPIRE_MINUTES=15
QQ_EMAIL_DOMAIN=qq.com

# Choose smtp or resend and fill only the selected provider's credentials.
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=REPLACE_WITH_SENDER_ADDRESS
SMTP_PASS=REPLACE_WITH_SMTP_AUTHORIZATION_CODE
SMTP_FROM=REPLACE_WITH_SENDER_ADDRESS
# RESEND_API_KEY=REPLACE_WITH_RESEND_API_KEY
# RESEND_FROM=REPLACE_WITH_VERIFIED_SENDER
# RESEND_SANDBOX_TO=
